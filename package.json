{
  "name": "trve-in_front-end",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "type-check": "tsc --noEmit",
    "dev": "next dev --turbopack",
    "build": "npm run type-check && next build",
    "start": "next start",
    "lint": "biome check .",
    "update-screenshot": "docker build -f scripts/Dockerfile.screenshot -t personal-website-screenshot . && docker run --rm -e SITE_DOMAIN=\"${SITE_DOMAIN:-skvggor}\" --env-file .env -v \"$(pwd)/public:/app/public\" personal-website-screenshot"
  },
  "dependencies": {
    "@biomejs/biome": "^2.3.11",
    "@phosphor-icons/react": "^2.1.10",
    "motion": "^12.40.0",
    "next": "^16.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4",
    "typescript": "^6.0.2"
  }
}
